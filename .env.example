# Fichier .env.example — Variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs réelles
# IMPORTANT : Ne jamais committer le .env avec les vraies valeurs !

# ── Base de données ───────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/production.db

# ── Sécurité JWT ──────────────────────────────────────────────────────────
SECRET_KEY=CHANGEZ_MOI_AVEC_UNE_LONGUE_PHRASE_ALEATOIRE_EN_PRODUCTION
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Email SMTP ────────────────────────────────────────────────────────────
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=votre_email@gmail.com
SMTP_PASSWORD=votre_app_password_gmail
EMAIL_FROM=noreply@biat-it.com.tn

# ── Environnement ─────────────────────────────────────────────────────────
ENVIRONMENT=production

# ── iTop (optionnel) ─────────────────────────────────────────────────────
ITOP_API_URL=
ITOP_USERNAME=
ITOP_PASSWORD=
